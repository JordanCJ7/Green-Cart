# Notification Service Configuration

# Server
PORT=5005
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
JWT_ACCESS_SECRET=your-super-secret-jwt-access-key
INTERNAL_API_KEY=your-shared-internal-api-key
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Database
MONGODB_URI=mongodb://localhost:27017/green-cart

# Email Service (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test@example.com
SMTP_PASSWORD=password
SMTP_FROM=noreply@greencart.com

# Service URLs
AUTHENTICATION_SERVICE_URL=http://localhost:5001
INVENTORY_SERVICE_URL=http://localhost:5002
PAYMENT_SERVICE_URL=http://localhost:5004
