# Payment Service Configuration

# Server
PORT=8083
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/greencart-payment

# JWT (shared secret from authentication service for token validation)
JWT_ACCESS_SECRET=your-jwt-access-secret-min-16-chars
JWT_ACCESS_EXPIRES_IN=15m

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10

# PayHere Integration
PAYHERE_MERCHANT_ID=1230185
# Localhost/dev secret
PAYHERE_SECRET_KEY=your-payhere-secret-key-here
# Localhost/dev webhook secret (usually same as merchant secret)
PAYHERE_WEBHOOK_SECRET=your-payhere-webhook-secret-here
# Optional: used automatically when NODE_ENV=production
PAYHERE_SECRET_KEY_PRODUCTION=your-payhere-production-secret-key-here
PAYHERE_WEBHOOK_SECRET_PRODUCTION=your-payhere-production-webhook-secret-here
PAYHERE_API_URL=https://sandbox.payhere.lk

# Callback/Webhook Configuration
PAYMENT_CALLBACK_URL=https://your-backend-domain/payment/webhook/payhere
PAYMENT_RETURN_URL=http://localhost:3000/checkout/success
PAYMENT_CANCEL_URL=http://localhost:3000/checkout/cancel

# Service-to-Service Communication (for future integration)
NOTIFICATION_SERVICE_URL=http://localhost:8084
INVENTORY_SERVICE_URL=http://localhost:8082
