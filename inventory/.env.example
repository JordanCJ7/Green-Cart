# Server
PORT=8082
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/GreenCartInventory?appName=Cluster0

# JWT Secrets — use long, random strings in production
JWT_ACCESS_SECRET=your_long_random_secret_key_here_for_access_tokens
JWT_REFRESH_SECRET=your_long_random_secret_key_here_for_refresh_tokens

# Token expiry
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10000

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000
