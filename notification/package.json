{
  "name": "green-cart-notification",
  "version": "1.0.0",
  "description": "Notification microservice for Green-Cart",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "cors": "2.8.6",
    "dotenv": "^17.3.1",
    "express": "4.19.2",
    "jsonwebtoken": "9.0.3",
    "mongoose": "8.9.5",
    "body-parser": "1.20.3",
    "zod": "3.24.1",
    "nodemailer": "6.9.14"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "20.17.14",
    "@types/nodemailer": "^6.4.15",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vitest/coverage-v8": "2.1.8",
    "eslint": "8.56.0",
    "tsx": "4.19.1",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
